{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Effect": "Allow",
			"Action": [
				"s3:PutObject",
				"s3:GetObject"
			],
			"Resource": "arn:aws:s3:::pdf-analyzer-1283/documents/*"
		},
		{
			"Effect": "Allow",
			"Action": [
				"dynamodb:PutItem",
				"dynamodb:GetItem"
			],
			"Resource": "arn:aws:dynamodb:*:*:table/INTERN_DOCUMENTS"
		},
		{
			"Effect": "Allow",
			"Action": "states:StartExecution",
			"Resource": "arn:aws:states:*:*:stateMachine:pdf-pipeline"
		}
	]
}